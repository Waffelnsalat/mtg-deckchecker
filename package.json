{
  "name": "mtg-deckchecker",
  "version": "0.4.3",
  "description": "API for parsing EDH decklists and resolving cards via Scryfall.",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm test",
    "audit:cards": "tsx scripts/card-role-audit.ts",
    "export:deck": "tsx src/exportDeck.ts",
    "start": "node dist/server.js",
    "test": "node scripts/run-tests.cjs"
  },
  "keywords": [
    "mtg",
    "edh",
    "scryfall",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "playwright-core": "^1.59.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
